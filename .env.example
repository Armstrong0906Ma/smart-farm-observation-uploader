# MongoDB database used for observations, upload records, and Dashboard data.
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=smart_farm

# Firebase Auth client config for Google Login
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to false only for local API debugging without Firebase Auth.
AUTH_REQUIRED=true

# mock | datahub-node-sdk
DATAHUB_UPLOADER=mock
DATAHUB_NODE_ID=fac73565-5615-4af0-9bd9-2350ddb621cb
DATAHUB_DCCS_API_URL=https://api-dccs-ensaas.education.wise-paas.com/
DATAHUB_DCCS_CREDENTIAL_KEY=
DATAHUB_USE_SECURE=false
DATAHUB_CONNECT_TIMEOUT_MS=30000
DATAHUB_PUBLISH_WAIT_MS=1500
DATAHUB_CLAIM_TIMEOUT_MS=600000
DATAHUB_PROCESS_TIMEOUT_MS=60000
DATAHUB_PROCESS_OUTPUT_LIMIT_BYTES=65536

# Optional Cloud Tasks async dispatch. Set all required core values or leave all empty.
TASKS_PROJECT_ID=
TASKS_LOCATION=
# Separate queues prevent a slow DataHub publish from blocking modeling dispatch.
TASKS_MODELING_QUEUE=
TASKS_DATAHUB_QUEUE=
# Recommended: configure this queue with maxConcurrentDispatches=1.
TASKS_DASHBOARD_QUEUE=
# Backward-compatible fallback used when the dedicated queues above are empty.
TASKS_QUEUE=
# Public base URL of this Next.js service, without a trailing slash.
TASK_HANDLER_URL=
# Optional: enables Cloud Run OIDC in addition to the internal task token.
TASK_SERVICE_ACCOUNT_EMAIL=
INTERNAL_TASK_TOKEN=

# Optional robot-camera source poller. Keep disabled until the Scheduler baseline run is verified.
AUTO_CAPTURE_ENABLED=false
AUTO_CAPTURE_SOURCE_URL=https://melodious-entremet-cdd8de.netlify.app/images.json
AUTO_CAPTURE_PLANT_ID=A-1-1
AUTO_CAPTURE_TIMEZONE=Asia/Taipei

# Hunyuan worker running locally or on a private GCE VM.
HUNYUAN_SERVICE_URL=http://127.0.0.1:8080
HUNYUAN_SERVICE_TOKEN=
HUNYUAN_DISPATCH_TIMEOUT_MS=120000
# Optional automatic resume for a suspended GCE worker. Set all three together.
HUNYUAN_GCE_PROJECT=
HUNYUAN_GCE_ZONE=
HUNYUAN_GCE_INSTANCE=
HUNYUAN_WAKE_TIMEOUT_MS=240000
HUNYUAN_WAKE_POLL_MS=3000
HUNYUAN_HEALTH_TIMEOUT_MS=5000

# Advantech Dashboard representative media. Only C-1-1 updates fixed panels
# 29 (front/mid), 33 (right), and 11 (analysis GIF).
# disabled | dry-run | live
DASHBOARD_PUBLISH_MODE=disabled
DASHBOARD_BASE_URL=https://dashboard.example.com
DASHBOARD_UID=
DASHBOARD_LOGIN_EMAIL=
DASHBOARD_LOGIN_USER=
DASHBOARD_LOGIN_PASSWORD=
DASHBOARD_LOGIN_TYPE=standard
DASHBOARD_ORG_ID=1
# Optional path used by the Dashboard's redirectto/Referer headers.
DASHBOARD_REDIRECT_TO=
DASHBOARD_REQUEST_TIMEOUT_MS=30000
DASHBOARD_LEASE_MS=300000
DASHBOARD_CLAIM_TIMEOUT_MS=600000
