# MongoDB database used for observations, upload records, and Dashboard data.
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=smart_farm

# Firebase Auth client config for Google Login
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to false only for local API debugging without Firebase Auth.
AUTH_REQUIRED=true

# mock | datahub-node-sdk
DATAHUB_UPLOADER=mock
DATAHUB_NODE_ID=fac73565-5615-4af0-9bd9-2350ddb621cb
DATAHUB_DCCS_API_URL=https://api-dccs-ensaas.education.wise-paas.com/
DATAHUB_DCCS_CREDENTIAL_KEY=
DATAHUB_USE_SECURE=false
DATAHUB_CONNECT_TIMEOUT_MS=30000
DATAHUB_PUBLISH_WAIT_MS=1500
DATAHUB_CLAIM_TIMEOUT_MS=600000
DATAHUB_PROCESS_TIMEOUT_MS=60000
DATAHUB_PROCESS_OUTPUT_LIMIT_BYTES=65536

# Optional Cloud Tasks async dispatch. Set all five required values or leave all empty.
TASKS_PROJECT_ID=
TASKS_LOCATION=
# Separate queues prevent a slow DataHub publish from blocking modeling dispatch.
TASKS_MODELING_QUEUE=
TASKS_DATAHUB_QUEUE=
# Backward-compatible fallback used for both task types when the two values above are empty.
TASKS_QUEUE=
# Public base URL of this Next.js service, without a trailing slash.
TASK_HANDLER_URL=
# Optional: enables Cloud Run OIDC in addition to the internal task token.
TASK_SERVICE_ACCOUNT_EMAIL=
INTERNAL_TASK_TOKEN=

# Hunyuan worker running locally or on a private GCE VM.
HUNYUAN_SERVICE_URL=http://127.0.0.1:8080
HUNYUAN_SERVICE_TOKEN=
HUNYUAN_DISPATCH_TIMEOUT_MS=120000
